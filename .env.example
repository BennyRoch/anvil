# Copy this file to .env.local for local development
# In Vercel: set these in Settings → Environment Variables

# ─── ANTHROPIC (server-side only, for AI Coach) ──────────────────────────────
# Used by the /api/generate-plan serverless function. NOT exposed to browsers.
ANTHROPIC_API_KEY=sk-ant-...

# ─── SUPABASE (client-side, safe to expose) ──────────────────────────────────
# These are exposed in the browser bundle. That's safe — the anon key is
# protected by Row Level Security policies in your Supabase database.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
